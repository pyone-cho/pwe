# Database
DATABASE_URL="postgresql://pwe_user:your_password@localhost:5432/pwe_dev"

# JWT
# IMPORTANT: Generate secure random secrets before running:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Application will fail to start without these set
JWT_SECRET="GENERATE-A-SECURE-RANDOM-STRING"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_SECRET="GENERATE-A-SECURE-RANDOM-STRING"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV=development

# CORS
FRONTEND_URL="http://localhost:5173"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880
